import pandas as pd
import numpy as np

# Load Dataset
df = pd.read_csv('Dataset/Superstore.csv.csv')

# Dataset Overview
print("Dataset Shape:")
print(df.shape)

print("\nColumn Names:")
print(df.columns)

print("\nData Types:")
print(df.info())

# Missing Values
print("\nMissing Values:")
print(df.isnull().sum())

# Duplicate Records
print("\nDuplicate Records:")
print(df.duplicated().sum())

# Remove Duplicates
df.drop_duplicates(inplace=True)

# Convert Date Columns
df['Order Date'] = pd.to_datetime(df['Order Date'])
df['Ship Date'] = pd.to_datetime(df['Ship Date'])

# Final Check
print("\nUpdated Dataset Information:")
print(df.info())

print("\nFirst Five Rows:")
print(df.head())

# Save Cleaned Dataset
df.to_csv('../Dataset/Superstore_Cleaned.csv', index=False)

print("\nData Cleaning Completed Successfully")
