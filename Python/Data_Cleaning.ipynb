import pandas as pd
import numpy as np

# Load Dataset
df = pd.read_csv(
    'Ecommerce-Analytics/Dataset/Superstore.csv',
    encoding='latin1'
)

print("Dataset Shape:")
print(df.shape)

print("\nColumns:")
print(df.columns.tolist())

print("\nMissing Values:")
print(df.isnull().sum())

print("\nDuplicate Records:")
print(df.duplicated().sum())

# Remove Duplicates
df.drop_duplicates(inplace=True)

# Convert Date Columns
df['Order Date'] = pd.to_datetime(df['Order Date'])
df['Ship Date'] = pd.to_datetime(df['Ship Date'])

print("\nData Types:")
print(df.dtypes)

# Save Cleaned Dataset
df.to_csv(
    'Ecommerce-Analytics/Dataset/Superstore_Cleaned.csv',
    index=False
)

print("\nData Cleaning Completed Successfully")
